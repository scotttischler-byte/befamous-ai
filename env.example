# Copy to .env.local (not committed)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# OpenAI
OPENAI_API_KEY=sk-...
# Optional — default gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Vercel Cron (set in Vercel env; required in production)
CRON_SECRET=long_random_string

# Strict cron auth in local dev (optional)
# CRON_STRICT=true

# Daily content job defaults (optional)
# BGE_DEFAULT_NICHE=fitness
# BGE_DEFAULT_GOAL=drive saves and follows
# BGE_DEFAULT_TONE=high-energy coach
# BGE_DEFAULT_PLATFORM=tiktok

# Optional: run ml/engine.py from learning-insights (needs python3 on host)
# USE_PYTHON_ML=true
