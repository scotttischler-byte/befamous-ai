# Copy to .env.local (gitignored)

# Supabase — server (dashboard + APIs)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase — browser (optional; reserved for future auth / client reads)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# OpenAI
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Vercel Cron (production)
CRON_SECRET=long_random_string

# Dev: set CRON_STRICT=true to require bearer token locally
# CRON_STRICT=true

# Cron: limit daily campaign to specific brand UUIDs (comma-separated). Empty = all brands.
# BGE_CRON_BRAND_IDS=

# Cron: if true, generate-daily uses lead-focused prompts for every brand.
# BGE_CRON_LEAD_MODE=true

# Optional Python ML bridge for learning (not used on Vercel serverless by default)
# USE_PYTHON_ML=true
